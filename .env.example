# CROO
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
CROO_SDK_KEY=croo_sk_...

# Service IDs from the CROO Dashboard, created via Agent Store > Configure >
# + Add Service. See README.md for the field manifest.
CROO_OPEN_POSITION_SERVICE_ID=
CROO_CLOSE_POSITION_SERVICE_ID=

# Optional. Defaults to https://mainnet.base.org if unset.
BASE_RPC_URL=

# Trading mode
# testnet | mainnet — gates the sp500 execution venue. The CROO order layer
# and bonds/Aerodrome leg always run on Base mainnet (CROO has no testnet).
TRADING_MODE=testnet

# Agent wallet
# The agent's own wallet address, from the Dashboard's Configure page. Not a
# private key, CROO holds the wallet's Executor key.
CROO_AGENT_AA_WALLET_ADDRESS=

# Owner key for the agent wallet, whitelisted for transfer/approve directly
# on the wallet, used to route swap/bridge principal through an unrestricted
# operating wallet. Self-custody this like any private key holding real value.
CROO_AGENT_OWNER_PRIVATE_KEY=

# Order minimums
MIN_ORDER_USDC_BONDS=5
MIN_ORDER_USDC_SP500=15

# sp500 execution (Ostium)
# Any EVM private key works. Use a dedicated
# key per network, separate from CROO_AGENT_OWNER_PRIVATE_KEY.
OSTIUM_TESTNET_PRIVATE_KEY=
OSTIUM_TESTNET_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Funded automatically per order via cross-chain bridging from the agent's
# own wallet, no manual funding needed.
OSTIUM_MAINNET_PRIVATE_KEY=
OSTIUM_MAINNET_RPC_URL=https://arb1.arbitrum.io/rpc

# Liquidation guard
GUARD_POLL_INTERVAL_SECONDS=60
GUARD_WARN_LIQUIDATION_DISTANCE_PCT=25
GUARD_ACT_LIQUIDATION_DISTANCE_PCT=10

# Test only: throwaway requester agent (scripts/test-negotiate.ts)
# Not part of the app's runtime config. A second agent registered purely to
# send test negotiations, see docs/ENV_SETUP.md. Not for production use.
CROO_REQUESTER_SDK_KEY=
